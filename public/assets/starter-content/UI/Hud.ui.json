{
  "schema": 1,
  "type": "ui",
  "name": "HUD",
  "preview": {
    "width": 1280,
    "height": 720
  },
  "root": {
    "id": "root",
    "widget": "Canvas",
    "props": {
      "align": "start",
      "justify": "start",
      "padding": 16
    },
    "children": [
      {
        "id": "hud",
        "widget": "Stack",
        "props": {
          "direction": "column",
          "gap": 6,
          "align": "start",
          "padding": 12,
          "background": "rgba(100, 109, 206, 0.55)",
          "radius": 8
        },
        "children": [
          {
            "id": "hpLabel",
            "widget": "Text",
            "props": {
              "text": { "bind": "player.speedLabel" },
              "fontSize": 13,
              "color": "#cfd6e2"
            },
            "children": []
          },
          {
            "id": "hpBar",
            "widget": "ProgressBar",
            "props": {
              "value": { "bind": "player.speed" },
              "max": 6
            },
            "children": []
          }
        ]
      }
    ]
  }
}
